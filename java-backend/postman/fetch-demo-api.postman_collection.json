{
  "info": {
    "_postman_id": "fetch-demo-api-collection",
    "name": "Fetch Demo API - 全栈数据流演示",
    "description": "Java 后端 API 接口集合，用于测试和调试批量保存等功能",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "批量保存接口",
      "item": [
        {
          "name": "批量保存用户 - 基础测试",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"id\": 1,\n    \"name\": \"张三\",\n    \"username\": \"zhangsan\",\n    \"email\": \"zhangsan@example.com\",\n    \"phone\": \"13800138001\",\n    \"website\": \"zhangsan.com\",\n    \"city\": \"北京\",\n    \"company\": \"测试科技公司\"\n  },\n  {\n    \"id\": 2,\n    \"name\": \"李四\",\n    \"username\": \"lisi\",\n    \"email\": \"lisi@example.com\",\n    \"phone\": \"13800138002\",\n    \"website\": \"lisi.com\",\n    \"city\": \"上海\",\n    \"company\": \"示例网络公司\"\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/batch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "batch"]
            },
            "description": "批量保存用户数据到数据库\n\n**断点建议位置：**\n- DatabaseController.batchSaveUsers() 方法入口\n- UserService.batchSaveUsers() for循环内\n\n**预期响应：**\n- savedCount: 新增的用户数量\n- updatedCount: 更新的用户数量\n- failedCount: 失败的数量"
          },
          "response": []
        },
        {
          "name": "批量保存用户 - JSONPlaceholder格式",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"id\": 11,\n    \"name\": \"Leanne Graham\",\n    \"username\": \"Bret\",\n    \"email\": \"Sincere@april.biz\",\n    \"address\": {\n      \"street\": \"Kulas Light\",\n      \"suite\": \"Apt. 556\",\n      \"city\": \"Gwenborough\",\n      \"zipcode\": \"92998-3874\"\n    },\n    \"phone\": \"1-770-736-8031 x56442\",\n    \"website\": \"hildegard.org\",\n    \"company\": {\n      \"name\": \"Romaguera-Crona\",\n      \"catchPhrase\": \"Multi-layered client-server neural-net\",\n      \"bs\": \"harness real-time e-markets\"\n    }\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/batch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "batch"]
            },
            "description": "测试嵌套格式的数据（与 JSONPlaceholder API 返回格式一致）\n\n**断点建议位置：**\n- UserService.convertFromFrontendData() 方法\n- 查看如何从嵌套的 address.city 和 company.name 提取数据"
          },
          "response": []
        },
        {
          "name": "批量保存用户 - 空数据测试",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/batch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "batch"]
            },
            "description": "测试空数组请求\n\n**预期响应：**\n- HTTP 400 Bad Request\n- success: false\n- message: 请求数据为空"
          },
          "response": []
        },
        {
          "name": "批量保存用户 - 更新已存在记录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"id\": 1,\n    \"name\": \"张三（已更新）\",\n    \"username\": \"zhangsan_updated\",\n    \"email\": \"zhangsan_new@example.com\",\n    \"phone\": \"13900139001\",\n    \"website\": \"zhangsan-new.com\",\n    \"city\": \"深圳\",\n    \"company\": \"新公司名称\"\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/batch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "batch"]
            },
            "description": "测试更新已存在的用户（ID=1）\n\n**断点建议位置：**\n- UserService.batchSaveUsers() 中的 existsById 检查\n\n**预期响应：**\n- updatedCount: 1\n- savedCount: 0"
          },
          "response": []
        }
      ]
    },
    {
      "name": "数据库查询接口",
      "item": [
        {
          "name": "获取所有用户",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "users"]
            },
            "description": "获取数据库中所有用户列表\n\n用于验证批量保存后的数据"
          },
          "response": []
        },
        {
          "name": "按ID获取用户",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "users", "1"]
            },
            "description": "按 ID 获取单个用户\n\n修改 URL 中的数字可查询不同用户"
          },
          "response": []
        },
        {
          "name": "按城市查询用户",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/users/city/北京",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "users", "city", "北京"]
            },
            "description": "按城市名称查询用户"
          },
          "response": []
        },
        {
          "name": "按邮箱搜索用户",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/users/search?email=example",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "users", "search"],
              "query": [
                {
                  "key": "email",
                  "value": "example"
                }
              ]
            },
            "description": "按邮箱关键字模糊搜索用户"
          },
          "response": []
        }
      ]
    },
    {
      "name": "统计接口",
      "item": [
        {
          "name": "获取数据库统计信息",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "stats"]
            },
            "description": "获取数据库统计信息，包含用户总数、城市列表、公司列表等"
          },
          "response": []
        },
        {
          "name": "获取用户总数",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/count",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "count"]
            },
            "description": "获取数据库中用户总数"
          },
          "response": []
        },
        {
          "name": "获取所有城市",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/cities",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "cities"]
            },
            "description": "获取所有不同的城市列表"
          },
          "response": []
        },
        {
          "name": "获取所有公司",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/companies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "companies"]
            },
            "description": "获取所有不同的公司列表"
          },
          "response": []
        }
      ]
    },
    {
      "name": "外部数据获取接口",
      "item": [
        {
          "name": "从外部API获取并保存所有用户",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/fetch-users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "fetch-users"]
            },
            "description": "从 JSONPlaceholder API 获取所有用户并保存到数据库\n\n会获取 10 个测试用户数据"
          },
          "response": []
        },
        {
          "name": "从外部API获取并保存单个用户",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/db/fetch-users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "db", "fetch-users", "1"]
            },
            "description": "从 JSONPlaceholder API 获取指定 ID 的用户并保存\n\n有效 ID 范围: 1-10"
          },
          "response": []
        }
      ]
    }
  ]
}
